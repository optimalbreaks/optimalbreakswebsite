# ============================================
# OPTIMAL BREAKS — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
#
# SECURITY:
# - The anon key is safe to expose client-side (it's rate-limited by RLS)
# - NEVER put service_role key in NEXT_PUBLIC_ variables
# - Enable RLS on all tables in Supabase dashboard
# ============================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# JWT legacy (anon) o nuevo formato sb_publishable_* (uno u otro):
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Solo servidor: JWT service_role o nuevo sb_secret_* (no NEXT_PUBLIC_*).
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_SECRET_KEY=sb_secret_...

# Postgres (scripts: npm run db:seed / db:migrate)
# Se leen .env y .env.local (este último gana si la misma clave está en ambos).
# A) URI: Supabase → Project Settings → Database → Connection string → URI
# B) O solo contraseña de BD + NEXT_PUBLIC_SUPABASE_URL → SUPABASE_DB_PASSWORD=...
# Alias URI: DATABASE_URL, DIRECT_URL, SUPABASE_DB_URL, POSTGRES_URL, POSTGRES_URL_NON_POOLING,
#   SUPABASE_POSTGRES_URL, POSTGRES_PRISMA_URL, SUPABASE_DATABASE_URL
# Alias contraseña: POSTGRES_PASSWORD, PGPASSWORD, DATABASE_PASSWORD
# La service_role (arriba) NO sustituye la contraseña de Postgres para ejecutar .sql con pg.
# DATABASE_SSL=0 desactiva SSL (no recomendado en Supabase).

# --------------------------------------------
# Artistas: npm run db:artist -- data/artists/archivo.json
# --------------------------------------------
# Sin Postgres: basta URL + SUPABASE_SERVICE_ROLE_KEY o SUPABASE_SECRET_KEY (arriba).
# Con Postgres: también puedes usar DATABASE_URL; el script preferirá Postgres.
# Migración previa recomendada: supabase/migrations/006_artist_extended_fields.sql

# --- Google Analytics 4 (público; opcional) ---
# Tras “Aceptar” cookies analíticas se carga gtag. Vercel: añade la misma variable al proyecto.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-VXDS1X91XW

# --- Opcional: agente de biografías (solo servidor) ---
# Guía: docs/ARTIST_AI_AGENT.md
# OPENAI_API_KEY=sk-proj-...
# OPENAI_MODEL=gpt-5.4       # opcional; por defecto gpt-5.4
# SERPAPI_API_KEY=...        # Google vía serpapi.com; si falla o falta, el agente sigue sin web
#
# Eventos: npm run db:events:enrich -- <slug> (SerpAPI web + OpenAI completa ficha)
#   y npm run db:events:poster -- <slug> (Google Imágenes + cartel → Storage)
# Requieren OPENAI_API_KEY + SERPAPI_API_KEY + URL + SERVICE_ROLE
